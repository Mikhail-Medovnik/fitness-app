{
	"compilerOptions": {
		"target": "ES2022",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",

		"rootDir": "./src",
		"outDir": "./dist",

		"strict": true,

		"baseUrl": ".",

		"paths": {
			"@config/*": ["src/config/*"],
			"@modules/*": ["src/modules/*"],
			"@middlewares/*": ["src/middlewares/*"],
			"@utils/*": ["src/utils/*"]
		},

		"esModuleInterop": true,
		"skipLibCheck": true,

		"forceConsistentCasingInFileNames": true,
		"noUncheckedIndexedAccess": true,
		"exactOptionalPropertyTypes": true,
		"ignoreDeprecations": "6.0"
	},
	"include": ["src"]
}
